      .btn-submit { padding:10px 28px; background:linear-gradient(135deg,var(--green-dark),var(--green-mid)); color:#fff; border:none; border-radius:10px; cursor:pointer; font-weight:600; font-family:'Poppins',sans-serif; font-size:0.95rem; }
      .btn-submit:hover { transform:translateY(-1px); box-shadow:0 4px 16px rgba(45,90,39,0.3); }
      .site-toast { position:fixed; top:20px; right:20px; padding:16px 28px; border-radius:12px; color:#fff; font-weight:600; font-size:0.9rem; z-index:2000; transform:translateX(120%); transition:transform 0.3s ease; box-shadow:0 4px 20px rgba(0,0,0,0.2); }
      .site-toast.show { transform:translateX(0); }
      .site-toast.success { background:#28a745; }
      .site-toast.error { background:#dc3545; }
      @media(max-width:600px) { .form-row { grid-template-columns:1fr; } }
    </style>

    <script>
      const lang = '<%= lang %>';

      // ORDER MODAL
      function openOrderModal(productId, productName, price) {
        document.getElementById('om_productId').value = productId;
        document.getElementById('om_product').value = productId;
        updateOrderPrice();
        document.getElementById('orderModal').classList.add('show');
      }
      function closeOrderModal() { document.getElementById('orderModal').classList.remove('show'); }

      function updateOrderPrice() {
        const sel = document.getElementById('om_product');
        const price = parseInt(sel.options[sel.selectedIndex].dataset.price);
        const qty = parseInt(document.getElementById('om_qty').value) || 1;
        document.getElementById('om_total').textContent = '₹' + (price * qty).toLocaleString('en-IN');
      }

      async function submitOrder(e) {
        e.preventDefault();
        const data = {
          customerName: document.getElementById('om_name').value,
          phone: document.getElementById('om_phone').value,
          address: document.getElementById('om_address').value,
          items: [{
            productId: document.getElementById('om_product').value,
            quantity: parseInt(document.getElementById('om_qty').value)
          }],
          notes: document.getElementById('om_notes').value
        };
        try {
          const res = await fetch('/api/order', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          if (res.ok) {
            const result = await res.json();
            closeOrderModal();
            showSiteToast(lang === 'mr' ? 'ऑर्डर यशस्वी! आम्ही लवकर संपर्क करू.' : 'Order placed! We will contact you soon.', 'success');
            document.getElementById('orderForm').reset();
            // Also open WhatsApp with order details
            const pName = document.getElementById('om_product').options[document.getElementById('om_product').selectedIndex].text;
            const waMsg = encodeURIComponent('Order #' + result.order.id + '\n' + data.customerName + '\n' + pName + ' x' + data.items[0].quantity + '\nTotal: ₹' + result.order.total);
            window.open('https://wa.me/919869352049?text=' + waMsg, '_blank');
          } else {
            showSiteToast(lang === 'mr' ? 'ऑर्डरमध्ये त्रुटी' : 'Error placing order', 'error');
          }
        } catch (err) {
          showSiteToast(lang === 'mr' ? 'नेटवर्क त्रुटी' : 'Network error', 'error');
        }
      }

      // SUBSCRIPTION MODAL
      function openSubscribeModal() {
        updateSubPrice();
        document.getElementById('subModal').classList.add('show');
      }
      function closeSubModal() { document.getElementById('subModal').classList.remove('show'); }

      function updateSubPrice() {
        const sel = document.getElementById('sm_product');
        const price = parseInt(sel.options[sel.selectedIndex].dataset.price);
        const qty = parseInt(document.getElementById('sm_qty').value) || 5;
        document.getElementById('sm_total').textContent = '₹' + (price * qty).toLocaleString('en-IN');
      }

      async function submitSubscription(e) {
        e.preventDefault();
        const data = {
          customerName: document.getElementById('sm_name').value,
          phone: document.getElementById('sm_phone').value,
          address: document.getElementById('sm_address').value,
          productId: document.getElementById('sm_product').value,
          quantity: parseInt(document.getElementById('sm_qty').value),
          frequency: document.getElementById('sm_freq').value,
          notes: document.getElementById('sm_notes').value
        };
        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          if (res.ok) {
            closeSubModal();
            showSiteToast(lang === 'mr' ? 'सबस्क्रिप्शन यशस्वी! धन्यवाद.' : 'Subscription activated! Thank you.', 'success');
            document.getElementById('subForm').reset();
            const pName = document.getElementById('sm_product').options[document.getElementById('sm_product').selectedIndex].text;
            const waMsg = encodeURIComponent('Subscription for ' + data.customerName + '\n' + pName + ' x' + data.quantity + 'kg (' + data.frequency + ')');
            window.open('https://wa.me/919869352049?text=' + waMsg, '_blank');
          } else {
            showSiteToast(lang === 'mr' ? 'सबस्क्रिप्शनमध्ये त्रुटी' : 'Error activating subscription', 'error');
          }
        } catch (err) {
          showSiteToast(lang === 'mr' ? 'नेटवर्क त्रुटी' : 'Network error', 'error');
        }
      }

      // TOAST
      function showSiteToast(msg, type) {
        const t = document.getElementById('siteToast');
        t.textContent = msg;
        t.className = 'site-toast ' + (type || 'success') + ' show';
        setTimeout(() => t.classList.remove('show'), 4000);
      }

      // ESC closes modals
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape') { closeOrderModal(); closeSubModal(); }
      });
    </script>
</body>
</html>
